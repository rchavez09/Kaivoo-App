{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Scoped capabilities for Kaivoo desktop app — deny-by-default",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$APPDATA/.kaivoo/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPDATA/vault/.attachments/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$APPDATA/.kaivoo/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPDATA/vault/.attachments/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$APPDATA/.kaivoo/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPDATA/vault/.attachments/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$APPDATA/.kaivoo/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPDATA/vault/.attachments/**" }
      ]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [
        { "path": "$APPDATA/.kaivoo/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPDATA/vault/.attachments/**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$APPDATA/.kaivoo/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPDATA/vault/.attachments/**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$APPDATA/.kaivoo/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPDATA/vault/.attachments/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$APPDATA/.kaivoo/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPDATA/vault/.attachments/**" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$APPDATA/.kaivoo/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPDATA/vault/.attachments/**" }
      ]
    },
    "updater:default",
    "process:allow-restart",
    "dialog:allow-open"
  ]
}
