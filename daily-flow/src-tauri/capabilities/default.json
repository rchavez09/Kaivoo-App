{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Scoped capabilities for Kaivoo desktop app — deny-by-default",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "sql:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$APPDATA/.kaivoo/**" },
        { "path": "$APPDATA/com.kaivoo.desktop/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$APPDATA/.kaivoo/**" },
        { "path": "$APPDATA/com.kaivoo.desktop/**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$APPDATA/.kaivoo/**" },
        { "path": "$APPDATA/com.kaivoo.desktop/**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$APPDATA/.kaivoo/**" },
        { "path": "$APPDATA/com.kaivoo.desktop/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$APPDATA/.kaivoo/**" },
        { "path": "$APPDATA/com.kaivoo.desktop/**" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$APPDATA/.kaivoo/**" },
        { "path": "$APPDATA/com.kaivoo.desktop/**" }
      ]
    }
  ]
}
