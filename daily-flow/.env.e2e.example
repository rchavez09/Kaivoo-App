# E2E test credentials — copy to .env.e2e and fill in
# These credentials are used by Playwright authenticated tests.
# Use a dedicated test account, NOT your personal account.

E2E_EMAIL=test@example.com
E2E_PASSWORD=your-test-password-here

# Optional: override base URL (e.g., Netlify deploy preview)
# PLAYWRIGHT_BASE_URL=https://deploy-preview-123--kaivoo.netlify.app
