---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout
  title="Flow by Kaivoo — Your own AI team. Any model. Your machine."
  description="Build your own AI team with any model, including local ones. Agent orchestration, workflows, persistent memory, and safe autonomy. Buy once, own it forever. $49 one-time."
>
  <!-- Nav -->
  <nav aria-label="Main navigation" class="fixed top-0 left-0 right-0 z-50 bg-sand/90 dark:bg-abyss-canvas/90 backdrop-blur-sm border-b border-navy/5 dark:border-white/5 transition-colors">
    <div class="max-w-content mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="font-brand text-xl font-medium tracking-tight text-navy dark:text-white">
        Flow <span class="text-sm font-normal text-storm dark:text-white/50">by Kaivoo</span>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm text-storm dark:text-white/60">
        <a href="#features" class="hover:text-navy dark:hover:text-white transition-colors">Features</a>
        <a href="#pricing" class="hover:text-navy dark:hover:text-white transition-colors">Pricing</a>
        <a href="#faq" class="hover:text-navy dark:hover:text-white transition-colors">FAQ</a>
      </div>
      <div class="flex items-center gap-3">
        <button
          onclick="toggleTheme()"
          class="w-9 h-9 rounded-lg border border-navy/10 dark:border-white/10 flex items-center justify-center text-storm dark:text-white/60 hover:bg-navy/5 dark:hover:bg-white/5 transition-colors"
          aria-label="Toggle theme"
        >
          <svg class="w-4 h-4 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 8.002-4.248Z" />
          </svg>
          <svg class="w-4 h-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
          </svg>
        </button>
        <a
          href="#pricing"
          class="bg-teal text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-teal-hover transition-colors"
        >
          Get Flow
        </a>
      </div>
    </div>
  </nav>

  <!-- Depth Bar -->
  <div class="depth-bar fixed top-16 left-0 right-0 z-50" aria-hidden="true"></div>

  <main>
    <!-- Hero -->
    <section class="pt-32 pb-20 md:pt-40 md:pb-28 px-6">
      <div class="max-w-content mx-auto text-center">
        <h1 class="font-brand text-display-mobile md:text-display font-medium text-navy dark:text-white max-w-4xl mx-auto">
          Your own AI team.<br class="hidden md:block" /> Any model. Your machine.
        </h1>
        <p class="mt-6 text-lg md:text-xl text-storm dark:text-white/60 max-w-2xl mx-auto leading-relaxed">
          Build AI agents with roles, skills, and workflows. Run any model, including free local ones. Persistent memory you can actually read. Safe autonomy with approval gates. All of it yours.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="#pricing"
            class="bg-teal text-white px-8 py-3.5 rounded-lg text-base font-medium hover:bg-teal-hover transition-colors"
          >
            Get Flow — $49
          </a>
          <a
            href="#features"
            class="border border-navy/15 dark:border-white/15 text-navy dark:text-white px-8 py-3.5 rounded-lg text-base font-medium hover:bg-navy/5 dark:hover:bg-white/5 transition-colors"
          >
            See what's inside
          </a>
        </div>
        <p class="mt-4 text-sm text-storm/70 dark:text-white/40">
          One-time purchase. No subscription. Desktop + web.
        </p>
      </div>
    </section>

    <!-- Hero Screenshot -->
    <section class="px-6 pb-20">
      <div class="max-w-content mx-auto">
        <div class="rounded-2xl border border-navy/10 dark:border-white/10 overflow-hidden shadow-xl shadow-navy/5 dark:shadow-black/20">
          <img
            src="/screenshots/hero_light.png"
            alt="Flow AI agent orchestrator — light mode"
            class="w-full block dark:hidden"
            width="1024"
            height="714"
            loading="eager"
          />
          <img
            src="/screenshots/hero_dark.png"
            alt="Flow AI agent orchestrator — dark mode"
            class="w-full hidden dark:block"
            width="1024"
            height="720"
            loading="lazy"
          />
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="py-20 md:py-28 px-6 bg-white dark:bg-abyss-card transition-colors">
      <div class="max-w-content mx-auto">
        <p class="text-sm font-medium text-teal uppercase tracking-wider mb-3">The platform</p>
        <h2 class="font-brand text-headline-mobile md:text-headline font-medium text-navy dark:text-white max-w-2xl">
          Everything you need to run autonomous AI agents.
        </h2>
        <p class="mt-4 text-storm dark:text-white/60 max-w-xl text-lg">
          Other AI tools give you a chat window. Flow gives you a team. Agents with roles, workflows with approval gates, memory you can read, and artifacts your AI builds for you.
        </p>

        <div class="mt-16 grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Feature 1: Agent Orchestrator -->
          <div class="group">
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">Agent orchestrator</h3>
            <p class="mt-2 text-storm dark:text-white/60 leading-relaxed">
              Build your own AI team. Create agents, assign any model (Claude, GPT, Gemini, Llama, or local via Ollama), define roles with system prompts, and set permissions. Ships with pre-loaded starter agents.
            </p>
          </div>

          <!-- Feature 2: Workflows -->
          <div class="group">
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 0 1 0 3.75H5.625a1.875 1.875 0 0 1 0-3.75Z" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">Workflows</h3>
            <p class="mt-2 text-storm dark:text-white/60 leading-relaxed">
              Chain agents and skills into multi-step pipelines. Set triggers (manual, scheduled, or event-based). Add approval gates at any step. Watch execution in real time with full thinking transparency.
            </p>
          </div>

          <!-- Feature 3: Skills -->
          <div class="group">
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 6.087c0-.355.186-.676.401-.959.221-.29.349-.634.349-1.003 0-1.036-1.007-1.875-2.25-1.875s-2.25.84-2.25 1.875c0 .369.128.713.349 1.003.215.283.401.604.401.959v0a.64.64 0 0 1-.657.643 48.491 48.491 0 0 1-4.163-.3c.186 1.613.293 3.25.315 4.907a.656.656 0 0 1-.658.663v0c-.355 0-.676-.186-.959-.401a1.647 1.647 0 0 0-1.003-.349c-1.036 0-1.875 1.007-1.875 2.25s.84 2.25 1.875 2.25c.369 0 .713-.128 1.003-.349.283-.215.604-.401.959-.401v0c.31 0 .555.26.532.57a48.039 48.039 0 0 1-.642 5.056c1.518.19 3.058.309 4.616.354a.64.64 0 0 0 .657-.643v0c0-.355-.186-.676-.401-.959a1.647 1.647 0 0 1-.349-1.003c0-1.035 1.008-1.875 2.25-1.875 1.243 0 2.25.84 2.25 1.875 0 .369-.128.713-.349 1.003-.215.283-.4.604-.4.959v0c0 .333.277.599.61.58a48.1 48.1 0 0 0 5.427-.63 48.05 48.05 0 0 0 .582-4.717.532.532 0 0 0-.533-.57v0c-.355 0-.676.186-.959.401-.29.221-.634.349-1.003.349-1.035 0-1.875-1.007-1.875-2.25s.84-2.25 1.875-2.25c.37 0 .713.128 1.003.349.283.215.604.401.96.401v0a.656.656 0 0 0 .658-.663 48.422 48.422 0 0 0-.37-5.36c-1.886.342-3.81.574-5.766.689a.578.578 0 0 1-.61-.58v0Z" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">Skills</h3>
            <p class="mt-2 text-storm dark:text-white/60 leading-relaxed">
              Give your agents abilities. Create skills from plain language descriptions. "Summarize my inbox." "Generate a weekly report." Pre-loaded starters included. Skills define what agents can do. Workflows define when.
            </p>
          </div>

          <!-- Feature 4: AI Artifacts -->
          <div class="group">
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">AI artifacts</h3>
            <p class="mt-2 text-storm dark:text-white/60 leading-relaxed">
              Your AI builds real things. Widgets, dashboards, calculators, reports. Rendered live in a sandboxed iframe. Save artifacts to your library, add them to any page, or export to your vault. Edit through conversation.
            </p>
          </div>

          <!-- Feature 5: Neuron Memory -->
          <div class="group">
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">Neuron memory</h3>
            <p class="mt-2 text-storm dark:text-white/60 leading-relaxed">
              Your AI remembers you, and you can read every word of it. Three tiers: core identity, active context, and episodic memory. Automatic consolidation keeps it sharp. No black box. Fully readable, editable, and exportable.
            </p>
          </div>

          <!-- Feature 6: Configurable Heartbeat -->
          <div class="group">
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">Configurable heartbeat</h3>
            <p class="mt-2 text-storm dark:text-white/60 leading-relaxed">
              Proactive AI that works without being asked. Morning briefings, evening summaries, custom intervals. Your agents notice patterns in your tasks, calendar, and journal, then surface insights on their own schedule.
            </p>
          </div>

          <!-- Feature 7: MCP Connections -->
          <div class="group">
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">MCP connections</h3>
            <p class="mt-2 text-storm dark:text-white/60 leading-relaxed">
              Connect to the Model Context Protocol ecosystem. Discover tools, connect with one click, manage active connections. Ships with File System and Flow Data MCPs built in. As the ecosystem grows, your agents grow with it.
            </p>
          </div>

          <!-- Feature 8: Safe Autonomy -->
          <div class="group">
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">Safe autonomy</h3>
            <p class="mt-2 text-storm dark:text-white/60 leading-relaxed">
              Confirmation gates on destructive actions. Skill-level permissions. Workflow approval gates before autonomous execution. Full audit trail with rollback. Powerful AI that is also accountable.
            </p>
          </div>

          <!-- Feature 9: Full Productivity Suite -->
          <div class="group">
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">Full productivity suite</h3>
            <p class="mt-2 text-storm dark:text-white/60 leading-relaxed">
              Journal, tasks, calendar, knowledge vault, routines, habits, insights, and universal search. The foundation your AI team works on top of. List, Kanban, and timeline views. Data export as JSON or Obsidian-compatible markdown.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Orchestrator Deep-Dive -->
    <section class="py-20 md:py-28 px-6">
      <div class="max-w-content mx-auto">
        <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
          <div>
            <p class="text-sm font-medium text-teal uppercase tracking-wider mb-3">The command center</p>
            <h2 class="font-brand text-headline-mobile md:text-headline font-medium text-navy dark:text-white">
              One page. Every agent, skill, and workflow.
            </h2>
            <p class="mt-4 text-storm dark:text-white/60 text-lg leading-relaxed">
              The Orchestrator is where you build and manage your AI team. Four tabs, one interface. Create agents with any model. Define skills from plain language. Chain steps into workflows with triggers and approval gates. Connect to the MCP ecosystem.
            </p>
            <p class="mt-4 text-storm dark:text-white/60 leading-relaxed">
              Everything is visual. No terminal, no YAML files, no coding required. Configure an agent in 30 seconds. Build a multi-step workflow in under a minute. Watch it execute with full thinking transparency so you always know what your AI is doing and why.
            </p>
            <div class="mt-8">
              <h3 class="text-sm font-medium text-navy dark:text-white uppercase tracking-wider mb-4">How it compares</h3>
              <div class="space-y-3">
                <div class="flex items-start gap-3">
                  <div class="w-5 h-5 rounded-full bg-ocean-foam dark:bg-ocean-abyss flex-shrink-0 flex items-center justify-center mt-0.5">
                    <svg class="w-3 h-3 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                  </div>
                  <p class="text-storm dark:text-white/60 text-sm">A configurable team of agents. ChatGPT gives you one model in one chat window.</p>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-5 h-5 rounded-full bg-ocean-foam dark:bg-ocean-abyss flex-shrink-0 flex items-center justify-center mt-0.5">
                    <svg class="w-3 h-3 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                  </div>
                  <p class="text-storm dark:text-white/60 text-sm">Multi-step workflows with approval gates. Not a single conversation turn. A pipeline you control.</p>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-5 h-5 rounded-full bg-ocean-foam dark:bg-ocean-abyss flex-shrink-0 flex items-center justify-center mt-0.5">
                    <svg class="w-3 h-3 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                  </div>
                  <p class="text-storm dark:text-white/60 text-sm">Any model, including local ones running on your own machine via Ollama. Zero lock-in.</p>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-5 h-5 rounded-full bg-ocean-foam dark:bg-ocean-abyss flex-shrink-0 flex items-center justify-center mt-0.5">
                    <svg class="w-3 h-3 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                  </div>
                  <p class="text-storm dark:text-white/60 text-sm">MCP connections extend your agents. Every new tool in the ecosystem becomes available to your team.</p>
                </div>
              </div>
            </div>
          </div>
          <div class="rounded-2xl border border-navy/10 dark:border-white/10 overflow-hidden shadow-lg shadow-navy/5 dark:shadow-black/20">
            <img
              src="/screenshots/orchestrator_light.png"
              alt="Flow Orchestrator page — light mode"
              class="w-full block dark:hidden"
              width="1024"
              height="717"
              loading="lazy"
            />
            <img
              src="/screenshots/orchestrator_dark.png"
              alt="Flow Orchestrator page — dark mode"
              class="w-full hidden dark:block"
              width="1024"
              height="720"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Built by AI -->
    <section class="py-20 md:py-28 px-6 bg-abyss-canvas text-white">
      <div class="max-w-content mx-auto text-center">
        <p class="text-sm font-medium text-ocean-shallow uppercase tracking-wider mb-3">The story</p>
        <h2 class="font-brand text-headline-mobile md:text-headline font-medium">
          I built this app using the app.
        </h2>
        <p class="mt-4 text-white/60 text-lg max-w-2xl mx-auto leading-relaxed">
          A solo founder and a team of 12 AI agents built a full production application. Not a marketing claim. The entire git history proves it. Every feature, every bug fix, every design decision was orchestrated through the same agent system that ships with the product. If this system can build software, imagine what it can do for your work.
        </p>
        <div class="mt-12 grid sm:grid-cols-3 gap-8 max-w-3xl mx-auto">
          <div>
            <div class="text-3xl font-brand font-medium text-ocean-shallow">33</div>
