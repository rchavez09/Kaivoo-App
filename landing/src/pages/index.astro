---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout
  title="Flow by Kaivoo — Your workflow. Your data. Your AI."
  description="Journal, tasks, calendar, and an AI concierge that actually remembers you — in one local-first app you own forever. $49 one-time."
>
  <!-- Nav -->
  <nav aria-label="Main navigation" class="fixed top-0 left-0 right-0 z-50 bg-sand/90 dark:bg-abyss-canvas/90 backdrop-blur-sm border-b border-navy/5 dark:border-white/5 transition-colors">
    <div class="max-w-content mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="font-brand text-xl font-medium tracking-tight text-navy dark:text-white">
        Flow <span class="text-sm font-normal text-storm dark:text-white/50">by Kaivoo</span>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm text-storm dark:text-white/60">
        <a href="#features" class="hover:text-navy dark:hover:text-white transition-colors">Features</a>
        <a href="#pricing" class="hover:text-navy dark:hover:text-white transition-colors">Pricing</a>
        <a href="#faq" class="hover:text-navy dark:hover:text-white transition-colors">FAQ</a>
      </div>
      <div class="flex items-center gap-3">
        <button
          onclick="toggleTheme()"
          class="w-9 h-9 rounded-lg border border-navy/10 dark:border-white/10 flex items-center justify-center text-storm dark:text-white/60 hover:bg-navy/5 dark:hover:bg-white/5 transition-colors"
          aria-label="Toggle theme"
        >
          <svg class="w-4 h-4 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 8.002-4.248Z" />
          </svg>
          <svg class="w-4 h-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
          </svg>
        </button>
        <a
          href="#pricing"
          class="bg-teal text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-teal-hover transition-colors"
        >
          Get Flow
        </a>
      </div>
    </div>
  </nav>

  <!-- Depth Bar -->
  <div class="depth-bar fixed top-16 left-0 right-0 z-50" aria-hidden="true"></div>

  <main>
    <!-- Hero -->
    <section class="pt-32 pb-20 md:pt-40 md:pb-28 px-6">
      <div class="max-w-content mx-auto text-center">
        <h1 class="font-brand text-display-mobile md:text-display font-medium text-navy dark:text-white max-w-4xl mx-auto">
          Your workflow. Your data.<br class="hidden md:block" /> Your AI.
        </h1>
        <p class="mt-6 text-lg md:text-xl text-storm dark:text-white/60 max-w-2xl mx-auto leading-relaxed">
          Journal, tasks, calendar, and an AI concierge that actually remembers you — in one local-first app you own forever.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="#pricing"
            class="bg-teal text-white px-8 py-3.5 rounded-lg text-base font-medium hover:bg-teal-hover transition-colors"
          >
            Get started — $49
          </a>
          <a
            href="#features"
            class="border border-navy/15 dark:border-white/15 text-navy dark:text-white px-8 py-3.5 rounded-lg text-base font-medium hover:bg-navy/5 dark:hover:bg-white/5 transition-colors"
          >
            See what's inside
          </a>
        </div>
        <p class="mt-4 text-sm text-storm/70 dark:text-white/40">
          One-time purchase. No subscription. macOS, Windows, and Linux.
        </p>
      </div>
    </section>

    <!-- Hero Screenshot -->
    <section class="px-6 pb-20">
      <div class="max-w-content mx-auto">
        <div class="rounded-2xl border border-navy/10 dark:border-white/10 overflow-hidden shadow-xl shadow-navy/5 dark:shadow-black/20">
          <img
            src="/screenshots/hero_light.png"
            alt="Flow daily planner — light mode"
            class="w-full block dark:hidden"
            width="1024"
            height="714"
            loading="eager"
          />
          <img
            src="/screenshots/hero_dark.png"
            alt="Flow daily planner — dark mode"
            class="w-full hidden dark:block"
            width="1024"
            height="720"
            loading="lazy"
          />
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="py-20 md:py-28 px-6 bg-white dark:bg-abyss-card transition-colors">
      <div class="max-w-content mx-auto">
        <p class="text-sm font-medium text-teal uppercase tracking-wider mb-3">Everything in one place</p>
        <h2 class="font-brand text-headline-mobile md:text-headline font-medium text-navy dark:text-white max-w-2xl">
          Replace the stack. Keep the workflow.
        </h2>
        <p class="mt-4 text-storm dark:text-white/60 max-w-xl text-lg">
          Notion for notes. Sunsama for planning. Obsidian for knowledge. Google Calendar for meetings. That's four apps, four subscriptions, and constant context-switching. Flow is one app.
        </p>

        <div class="mt-16 grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Feature 1: Day Execution -->
          <div class="group">
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">Day execution</h3>
            <p class="mt-2 text-storm dark:text-white/60 leading-relaxed">
              Today is your command center. Tasks, meetings, routines, and a daily brief — all on one screen. End each day with a guided shutdown ritual that routes unfinished work and plans tomorrow.
            </p>
          </div>

          <!-- Feature 2: AI Concierge -->
          <div class="group">
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">AI concierge</h3>
            <p class="mt-2 text-storm dark:text-white/60 leading-relaxed">
              An assistant that knows your entire workspace. Create tasks, search notes, check your schedule, log a habit — it takes action directly in the app. Bring your own API key from any provider.
            </p>
          </div>

          <!-- Feature 3: Journal & Notes -->
          <div class="group">
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">Journal and notes</h3>
            <p class="mt-2 text-storm dark:text-white/60 leading-relaxed">
              A rich-text daily canvas that auto-saves every keystroke. Write naturally, then let AI surface tasks and action items hiding in your notes. Browse your full history from the calendar sidebar.
            </p>
          </div>

          <!-- Feature 4: Tasks & Projects -->
          <div class="group">
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">Tasks and projects</h3>
            <p class="mt-2 text-storm dark:text-white/60 leading-relaxed">
              Switch between list, Kanban board, and timeline views. Subtasks with drag-to-reorder, recurring tasks, priority levels, and project grouping with visual progress tracking.
            </p>
          </div>

          <!-- Feature 5: Knowledge Vault -->
          <div class="group">
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.061-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.379a1.5 1.5 0 0 1-1.06-.44Z" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">Knowledge vault</h3>
            <p class="mt-2 text-storm dark:text-white/60 leading-relaxed">
              Organize your knowledge into a nested topic tree with wiki-style pages, file attachments, and linked captures. Browse everything in a Finder-style file browser. Export as Obsidian-compatible markdown.
            </p>
          </div>

          <!-- Feature 6: Calendar -->
          <div class="group">
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 9v7.5" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">Calendar</h3>
            <p class="mt-2 text-storm dark:text-white/60 leading-relaxed">
              Month, week, and day views with tasks and meetings side-by-side. Open any day's full review to see every note, task, routine, and capture from that day in one summary panel.
            </p>
          </div>

          <!-- Feature 7: Routines & Habits -->
          <div class="group">
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 0 0-3.7-3.7 48.678 48.678 0 0 0-7.324 0 4.006 4.006 0 0 0-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 0 0 3.7 3.7 48.656 48.656 0 0 0 7.324 0 4.006 4.006 0 0 0 3.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3-3 3" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">Routines and habits</h3>
            <p class="mt-2 text-storm dark:text-white/60 leading-relaxed">
              Schedule habits in morning, afternoon, and evening blocks. Track streaks, view weekly completion analytics, and archive habits without losing history. Boolean or count-based targets.
            </p>
          </div>

          <!-- Feature 8: Insights -->
          <div class="group">
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">Insights</h3>
            <p class="mt-2 text-storm dark:text-white/60 leading-relaxed">
              Weekly productivity stats, a GitHub-style activity heatmap, and per-routine completion breakdowns. Navigate backward through any past week to understand your long-term patterns.
            </p>
          </div>

          <!-- Feature 9: Search -->
          <div class="group">
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">Universal search</h3>
            <p class="mt-2 text-storm dark:text-white/60 leading-relaxed">
              A command palette that searches tasks, notes, projects, meetings, topics, captures, and habits simultaneously. On desktop, powered by SQLite FTS5 for blazing-fast offline results.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Soul File Section -->
    <section class="py-20 md:py-28 px-6">
      <div class="max-w-content mx-auto">
        <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
          <div>
            <p class="text-sm font-medium text-teal uppercase tracking-wider mb-3">AI that remembers you</p>
            <h2 class="font-brand text-headline-mobile md:text-headline font-medium text-navy dark:text-white">
              Your AI's memory is a file you own.
            </h2>
            <p class="mt-4 text-storm dark:text-white/60 text-lg leading-relaxed">
              The Soul File is a readable, editable, exportable record of everything your AI concierge knows about you. Your name, your goals, your working style, your communication preferences. Stored on your device, never on a vendor's server.
            </p>
            <p class="mt-4 text-storm dark:text-white/60 leading-relaxed">
              Give your concierge a name and personality. Tell it how you work. It learns from every conversation and you can see, edit, or delete every fact it remembers — no black boxes.
            </p>
            <div class="mt-8">
              <h3 class="text-sm font-medium text-navy dark:text-white uppercase tracking-wider mb-4">How it compares</h3>
              <div class="space-y-3">
                <div class="flex items-start gap-3">
                  <div class="w-5 h-5 rounded-full bg-ocean-foam dark:bg-ocean-abyss flex-shrink-0 flex items-center justify-center mt-0.5">
                    <svg class="w-3 h-3 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                  </div>
                  <p class="text-storm dark:text-white/60 text-sm">Read, edit, and export your AI's memory. ChatGPT lets you delete entries — that's it.</p>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-5 h-5 rounded-full bg-ocean-foam dark:bg-ocean-abyss flex-shrink-0 flex items-center justify-center mt-0.5">
                    <svg class="w-3 h-3 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                  </div>
                  <p class="text-storm dark:text-white/60 text-sm">Stored on your device. Not on a vendor's server that can reset without warning.</p>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-5 h-5 rounded-full bg-ocean-foam dark:bg-ocean-abyss flex-shrink-0 flex items-center justify-center mt-0.5">
                    <svg class="w-3 h-3 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                  </div>
                  <p class="text-storm dark:text-white/60 text-sm">Your concierge sees your tasks, calendar, and journal. ChatGPT sees nothing beyond the chat.</p>
                </div>
                <div class="flex items-start gap-3">
                  <div class="w-5 h-5 rounded-full bg-ocean-foam dark:bg-ocean-abyss flex-shrink-0 flex items-center justify-center mt-0.5">
                    <svg class="w-3 h-3 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                    </svg>
                  </div>
                  <p class="text-storm dark:text-white/60 text-sm">Choose any AI model — Claude, ChatGPT, Gemini, Llama, or a fully local Ollama instance.</p>
                </div>
              </div>
            </div>
          </div>
          <div class="rounded-2xl border border-navy/10 dark:border-white/10 overflow-hidden shadow-lg shadow-navy/5 dark:shadow-black/20">
            <img
              src="/screenshots/soul-file_light.png"
              alt="Flow Soul File settings — light mode"
              class="w-full block dark:hidden"
              width="1024"
              height="717"
              loading="lazy"
            />
            <img
              src="/screenshots/soul-file_dark.png"
              alt="Flow Soul File settings — dark mode"
              class="w-full hidden dark:block"
              width="1024"
              height="720"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Local-First Section -->
    <section class="py-20 md:py-28 px-6 bg-abyss-canvas text-white">
      <div class="max-w-content mx-auto text-center">
        <p class="text-sm font-medium text-ocean-shallow uppercase tracking-wider mb-3">Local-first by design</p>
        <h2 class="font-brand text-headline-mobile md:text-headline font-medium">
          Your data never leaves your machine.
        </h2>
        <p class="mt-4 text-white/60 text-lg max-w-2xl mx-auto leading-relaxed">
          Everything is stored in a local SQLite database on your device. No cloud dependency. No telemetry. No analytics. Works fully offline. Export everything as JSON or Obsidian-compatible markdown at any time.
        </p>
        <div class="mt-12 grid sm:grid-cols-3 gap-8 max-w-3xl mx-auto">
          <div>
            <div class="text-3xl font-brand font-medium text-ocean-shallow">0</div>
            <p class="mt-2 text-white/50 text-sm">Analytics trackers</p>
          </div>
          <div>
            <div class="text-3xl font-brand font-medium text-ocean-shallow">8</div>
            <p class="mt-2 text-white/50 text-sm">AI providers supported</p>
          </div>
          <div>
            <div class="text-3xl font-brand font-medium text-ocean-shallow">100%</div>
            <p class="mt-2 text-white/50 text-sm">Offline capable</p>
          </div>
        </div>
      </div>
    </section>

    <!-- BYO Keys -->
    <section class="py-20 md:py-28 px-6">
      <div class="max-w-content mx-auto text-center">
        <p class="text-sm font-medium text-teal uppercase tracking-wider mb-3">Bring your own keys</p>
        <h2 class="font-brand text-headline-mobile md:text-headline font-medium text-navy dark:text-white max-w-2xl mx-auto">
          Your AI. Your provider. Your costs.
        </h2>
        <p class="mt-4 text-storm dark:text-white/60 text-lg max-w-2xl mx-auto leading-relaxed">
          Connect your own API key from any provider. Your key is AES-GCM encrypted on your device and never touches our servers. Switch providers any time.
        </p>
        <div class="mt-12 flex flex-wrap justify-center gap-4">
          {['OpenAI', 'Anthropic (Claude)', 'Google Gemini', 'Groq', 'Mistral', 'DeepSeek', 'OpenRouter', 'Ollama (local)'].map(provider => (
