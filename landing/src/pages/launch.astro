---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout
  title="Flow by Kaivoo. Your AI team is almost ready."
  description="AI agents that actually work for you. Multi-agent orchestration, persistent memory, and safe autonomy. Your machine. Your models. Your data. Launching April 16, 2026."
>
  <!-- Nav -->
  <nav aria-label="Main navigation" class="fixed top-0 left-0 right-0 z-50 bg-sand/90 dark:bg-abyss-canvas/90 backdrop-blur-sm border-b border-navy/5 dark:border-white/5 transition-colors">
    <div class="max-w-content mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/launch" class="font-brand text-xl font-medium tracking-tight text-navy dark:text-white">
        Flow <span class="text-sm font-normal text-storm dark:text-white/50">by Kaivoo</span>
      </a>
      <div class="flex items-center gap-3">
        <button
          onclick="toggleTheme()"
          class="w-9 h-9 rounded-lg border border-navy/10 dark:border-white/10 flex items-center justify-center text-storm dark:text-white/60 hover:bg-navy/5 dark:hover:bg-white/5 transition-colors"
          aria-label="Toggle theme"
        >
          <svg class="w-4 h-4 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 8.002-4.248Z" />
          </svg>
          <svg class="w-4 h-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
          </svg>
        </button>
        <a
          href="#notify"
          class="bg-teal text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-teal-hover transition-colors"
        >
          Get early access
        </a>
      </div>
    </div>
  </nav>

  <!-- Depth Bar -->
  <div class="depth-bar fixed top-16 left-0 right-0 z-50" aria-hidden="true"></div>

  <main>
    <!-- Hero -->
    <section class="pt-32 pb-16 md:pt-40 md:pb-20 px-6">
      <div class="max-w-content mx-auto text-center">
        <p class="text-sm font-medium text-teal uppercase tracking-wider mb-4">Launching April 16, 2026</p>
        <h1 class="font-brand text-display-mobile md:text-display font-medium text-navy dark:text-white max-w-4xl mx-auto">
          A team of AI agents built this app.<br class="hidden md:block" /> Now they work for you.
        </h1>
        <p class="mt-6 text-lg md:text-xl text-storm dark:text-white/60 max-w-2xl mx-auto leading-relaxed">
          Your own AI team. Any model, including local ones. Persistent memory you can actually read. Buy once, and it's yours forever.
        </p>

        <!-- Countdown -->
        <div id="countdown" class="mt-10" aria-label="Countdown to launch">
          <div class="flex gap-4 md:gap-6 justify-center">
            <div class="text-center">
              <div class="font-brand text-3xl md:text-5xl font-medium text-navy dark:text-white">--</div>
              <div class="text-xs md:text-sm text-storm dark:text-white/50 mt-1">days</div>
            </div>
            <div class="text-center">
              <div class="font-brand text-3xl md:text-5xl font-medium text-navy dark:text-white">--</div>
              <div class="text-xs md:text-sm text-storm dark:text-white/50 mt-1">hours</div>
            </div>
            <div class="text-center">
              <div class="font-brand text-3xl md:text-5xl font-medium text-navy dark:text-white">--</div>
              <div class="text-xs md:text-sm text-storm dark:text-white/50 mt-1">min</div>
            </div>
            <div class="text-center">
              <div class="font-brand text-3xl md:text-5xl font-medium text-navy dark:text-white">--</div>
              <div class="text-xs md:text-sm text-storm dark:text-white/50 mt-1">sec</div>
            </div>
          </div>
        </div>

        <!-- Email Capture -->
        <div class="mt-10 max-w-md mx-auto">
          <form class="email-form flex flex-col sm:flex-row gap-3">
            <input
              type="email"
              required
              placeholder="you@example.com"
              class="flex-1 px-4 py-3 rounded-lg border border-navy/15 dark:border-white/15 bg-white dark:bg-abyss-elevated text-navy dark:text-white placeholder:text-storm/50 dark:placeholder:text-white/30 focus:outline-none focus:ring-2 focus:ring-teal/50 text-sm"
            />
            <button
              type="submit"
              class="bg-teal text-white px-6 py-3 rounded-lg text-sm font-medium hover:bg-teal-hover transition-colors whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Get early access
            </button>
          </form>
          <div class="form-message mt-3 text-sm"></div>
          <p id="subscriber-count" class="mt-3 text-xs text-storm/80 dark:text-white/50">&nbsp;</p>
          <p class="mt-1 text-xs text-storm/80 dark:text-white/50">
            No spam. Unsubscribe anytime.
          </p>
        </div>
      </div>
    </section>

    <!-- The Shift — OAR framing -->
    <section class="py-16 md:py-24 px-6 bg-white dark:bg-abyss-card transition-colors">
      <div class="max-w-2xl mx-auto">
        <p class="text-sm font-medium text-teal uppercase tracking-wider mb-6 text-center">The shift</p>
        <p class="text-storm dark:text-white/60 text-lg leading-relaxed">
          AI crossed a line this year. It stopped suggesting and started <strong class="text-navy dark:text-white font-medium">doing</strong>. Building presentations, managing workflows, writing and reviewing code. Remembering your preferences across every conversation.
        </p>
        <p class="mt-4 text-storm dark:text-white/60 text-lg leading-relaxed">
          The people using this right now are mostly developers with terminal access and $200/month in API costs. That kind of power shouldn&rsquo;t require a CS degree.
        </p>
        <p class="mt-4 text-storm dark:text-white/60 text-lg leading-relaxed">
          Flow puts autonomous AI agents in a polished app anyone can use. Pick any model, including free local ones running on your own machine. Your AI remembers you, and you can read every word of its memory. Safety controls keep it accountable.
        </p>
        <p class="mt-6 text-navy dark:text-white text-xl font-medium leading-relaxed">
          One purchase. Yours forever. <strong>You</strong> own everything.
        </p>
      </div>
    </section>

    <!-- What's Coming -->
    <section class="py-16 md:py-24 px-6">
      <div class="max-w-content mx-auto">
        <p class="text-sm font-medium text-teal uppercase tracking-wider mb-3 text-center">What you get</p>
        <h2 class="font-brand text-headline-mobile md:text-headline font-medium text-navy dark:text-white text-center max-w-2xl mx-auto">
          Four things no other AI app gives you.
        </h2>
        <p class="mt-4 text-storm dark:text-white/60 text-lg text-center max-w-xl mx-auto">
          A real AI team with roles, skills, memory, and safety rails. Any model. Your machine. Not another chatbot.
        </p>

        <div class="mt-14 grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
          <!-- Orchestrator -->
          <div>
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">Agent orchestrator</h3>
            <p class="mt-2 text-storm dark:text-white/60 text-sm leading-relaxed">
              Build your own AI team. Assign any model, define roles, chain agents into workflows with approval gates.
            </p>
          </div>

          <!-- Artifacts -->
          <div>
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 0 0-5.78 1.128 2.25 2.25 0 0 1-2.4 2.245 4.5 4.5 0 0 0 8.4-2.245c0-.399-.078-.78-.22-1.128Zm0 0a15.998 15.998 0 0 0 3.388-1.62m-5.043-.025a15.994 15.994 0 0 1 1.622-3.395m3.42 3.42a15.995 15.995 0 0 0 4.764-4.648l3.876-5.814a1.151 1.151 0 0 0-1.597-1.597L14.146 6.32a15.996 15.996 0 0 0-4.649 4.763m3.42 3.42a6.776 6.776 0 0 0-3.42-3.42" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">AI artifacts</h3>
            <p class="mt-2 text-storm dark:text-white/60 text-sm leading-relaxed">
              Your AI builds real things. Widgets, dashboards, reports. Rendered live in a sandbox. Save them to your library.
            </p>
          </div>

          <!-- Safety -->
          <div>
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">Safe autonomy</h3>
            <p class="mt-2 text-storm dark:text-white/60 text-sm leading-relaxed">
              Confirmation gates on destructive actions. Skill-level permissions. Full audit trail. Your AI is powerful and accountable.
            </p>
          </div>

          <!-- Memory -->
          <div>
            <div class="w-10 h-10 rounded-lg bg-ocean-foam dark:bg-ocean-abyss flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-teal dark:text-ocean-shallow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z" />
              </svg>
            </div>
            <h3 class="font-brand text-lg font-medium text-navy dark:text-white">Neuron memory</h3>
            <p class="mt-2 text-storm dark:text-white/60 text-sm leading-relaxed">
              Your AI remembers you, and you can read every word. No black box. A tiered memory system you own and control.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Build Progress -->
    <section class="py-16 md:py-24 px-6">
      <div class="max-w-content mx-auto">
        <div class="max-w-2xl mx-auto">
          <p class="text-sm font-medium text-teal uppercase tracking-wider mb-3 text-center">Built in public</p>
          <h2 class="font-brand text-headline-mobile md:text-headline font-medium text-navy dark:text-white text-center">
            Watch it come together.
          </h2>
          <p class="mt-4 text-storm dark:text-white/60 text-center">
            Real progress. Real sprints. No vaporware.
          </p>

          <!-- Progress Bar -->
          <div class="mt-10">
            <div class="w-full bg-navy/10 dark:bg-white/10 rounded-full h-3 overflow-hidden">
              <div id="progress-bar" class="depth-bar h-full rounded-full transition-all duration-1000" style="width: 0%"></div>
            </div>
            <p id="progress-text" class="mt-2 text-sm text-storm dark:text-white/50 text-center">Loading...</p>
          </div>

          <!-- Milestone Feed -->
          <div id="milestones-feed" class="mt-8 divide-y divide-navy/5 dark:divide-white/5">
            <p class="text-storm dark:text-white/50 text-sm py-3 text-center">Loading milestones...</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Founder Story -->
    <section class="py-16 md:py-24 px-6 bg-white dark:bg-abyss-card transition-colors">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-sm font-medium text-teal uppercase tracking-wider mb-3">The story</p>
        <h2 class="font-brand text-headline-mobile md:text-headline font-medium text-navy dark:text-white">
          I built this app using the app.
        </h2>
        <p class="mt-6 text-storm dark:text-white/60 text-lg leading-relaxed">
          33 sprints. 12 AI agents. Zero employees. Flow was built by a solo founder and a team of AI agents working together. Not a marketing claim. The entire git history proves it. Every feature, every bug fix, every design decision was orchestrated through the same agent system that ships with the product.
        </p>
        <p class="mt-4 text-storm dark:text-white/60 text-lg leading-relaxed">
          If this system can build software, imagine what it can do for your daily work. Now I&rsquo;m putting it in your hands.
        </p>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section id="notify" class="py-16 md:py-24 px-6 bg-abyss-canvas text-white">
      <div class="max-w-content mx-auto text-center">
        <h2 class="font-brand text-headline-mobile md:text-headline font-medium">
          Be there on day one.
        </h2>
        <p class="mt-4 text-white/60 text-lg max-w-xl mx-auto">
          Founding members get early access and a price that locks in forever. Use any model, including free local ones. Pay once, own it for life.
        </p>
        <div class="mt-10 max-w-md mx-auto">
          <form class="email-form flex flex-col sm:flex-row gap-3">
            <input
              type="email"
              required
              placeholder="you@example.com"
              class="flex-1 px-4 py-3 rounded-lg border border-white/15 bg-abyss-elevated text-white placeholder:text-white/30 focus:outline-none focus:ring-2 focus:ring-teal/50 text-sm"
            />
            <button
              type="submit"
              class="bg-teal text-white px-6 py-3 rounded-lg text-sm font-medium hover:bg-teal-hover transition-colors whitespace-nowrap disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Get early access
            </button>
          </form>
          <div class="form-message mt-3 text-sm"></div>
          <p id="subscriber-count-bottom" class="mt-3 text-xs text-white/50">&nbsp;</p>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="py-12 px-6 border-t border-navy/5 dark:border-white/5">
    <div class="max-w-content mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
        <div>
          <span class="font-brand text-lg font-medium text-navy dark:text-white">Flow <span class="text-sm font-normal text-storm dark:text-white/50">by Kaivoo</span></span>
          <p class="mt-1 text-sm text-storm dark:text-white/60">Your own AI team. Your machine. Your data.</p>
        </div>
        <div class="flex flex-wrap gap-6 text-sm text-storm dark:text-white/60">
          <a href="/privacy" class="hover:text-navy dark:hover:text-white transition-colors">Privacy Policy</a>
          <a href="mailto:support@kaivoo.app" class="hover:text-navy dark:hover:text-white transition-colors">Contact</a>
        </div>
      </div>
      <div class="depth-bar mt-8 rounded-full" aria-hidden="true"></div>
      <p class="mt-6 text-xs text-storm/50 dark:text-white/30">
        &copy; {new Date().getFullYear()} Kaivoo Media. All rights reserved.
      </p>
    </div>
  </footer>

  <!-- Interactive Scripts -->
  <script>
    import { supabase } from '../lib/supabase';

    // --- Countdown Timer ---
    function startCountdown() {
      const target = new Date('2026-04-16T09:00:00-07:00').getTime();
      const el = document.getElementById('countdown');
      if (!el) return;

      function update() {
        const now = Date.now();
        const diff = target - now;
        if (diff <= 0) {
          el.innerHTML = '<a href="/" class="inline-block bg-teal text-white px-8 py-3.5 rounded-lg text-base font-medium hover:bg-teal-hover transition-colors">We\'re live. Get Flow</a>';
          return;
        }
        const days = Math.floor(diff / 86400000);
        const hours = Math.floor((diff % 86400000) / 3600000);
        const minutes = Math.floor((diff % 3600000) / 60000);
        const seconds = Math.floor((diff % 60000) / 1000);

        const parts = [
          { value: days, label: 'days' },
          { value: hours, label: 'hours' },
          { value: minutes, label: 'min' },
          { value: seconds, label: 'sec' },
        ];

        el.innerHTML = `<div class="flex gap-4 md:gap-6 justify-center">${parts.map(p => `
          <div class="text-center">
            <div class="font-brand text-3xl md:text-5xl font-medium text-navy dark:text-white">${String(p.value).padStart(2, '0')}</div>
            <div class="text-xs md:text-sm text-storm dark:text-white/50 mt-1">${p.label}</div>
          </div>
        `).join('')}</div>`;
      }

      update();
      setInterval(update, 1000);
    }

    // --- Email Capture ---
    function setupEmailForms() {
      const forms = document.querySelectorAll<HTMLFormElement>('.email-form');
      const params = new URLSearchParams(window.location.search);
      const source = params.get('ref') || 'landing';

      forms.forEach(form => {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const input = form.querySelector<HTMLInputElement>('input[type="email"]');
          const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
          const msg = form.querySelector<HTMLElement>('.form-message') || form.nextElementSibling as HTMLElement;
          if (!input || !btn) return;

          const email = input.value.trim();
          if (!email) return;

          btn.disabled = true;
          btn.textContent = 'Securing your spot...';
          if (msg) msg.textContent = '';

          const { error } = await supabase
            .from('subscribers')
            .insert({ email, source });

          if (error) {
            if (error.code === '23505') {
              if (msg) {
                msg.textContent = "You're already on the list!";
                msg.className = 'form-message mt-3 text-sm text-teal';
              }
            } else {
              if (msg) {
                msg.textContent = 'Something went wrong. Try again.';
                msg.className = 'form-message mt-3 text-sm text-ember';
              }
            }
          } else {
            if (msg) {
              msg.textContent = "You're in. Early access is yours.";
              msg.className = 'form-message mt-3 text-sm text-teal';
            }
            input.value = '';
          }

          btn.disabled = false;
          btn.textContent = 'Get early access';
          loadSubscriberCount();
        });
      });
    }

    // --- Milestones Feed ---
    async function loadMilestones() {
      const feed = document.getElementById('milestones-feed');
      const progressBar = document.getElementById('progress-bar');
      const progressText = document.getElementById('progress-text');
      if (!feed) return;

      const { data, error } = await supabase
        .from('milestones')
        .select('*')
        .order('sort_order', { ascending: true });

      if (error || !data) {
        feed.innerHTML = '<p class="text-storm dark:text-white/50 text-sm py-3 text-center">Could not load milestones.</p>';
        return;
      }

      const total = data.length;
      const completed = data.filter((m: any) => m.completed).length;
      const pct = total > 0 ? Math.round((completed / total) * 100) : 0;

      if (progressBar) {
        progressBar.style.width = `${pct}%`;
      }
      if (progressText) {
        progressText.textContent = `${completed} of ${total} milestones complete`;
      }

      feed.innerHTML = data.map((m: any) => `
        <div class="flex items-start gap-3 py-3 ${m.completed ? 'opacity-60' : ''}">
          <div class="w-6 h-6 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5 ${
            m.completed
              ? 'bg-teal/20 dark:bg-teal/10'
              : 'border-2 border-navy/15 dark:border-white/15'
          }">
            ${m.completed
              ? '<svg class="w-3.5 h-3.5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>'
              : ''
            }
          </div>
          <div>
            <p class="font-medium text-navy dark:text-white text-sm ${m.completed ? 'line-through' : ''}">
              ${m.title}${m.sprint_number ? ` <span class="text-storm dark:text-white/40 font-normal text-xs">Sprint ${m.sprint_number}</span>` : ''}
            </p>
            ${m.description ? `<p class="text-storm dark:text-white/50 text-xs mt-0.5">${m.description}</p>` : ''}
          </div>
        </div>
      `).join('');
    }

    // --- Subscriber Count ---
    async function loadSubscriberCount() {
      const els = [
        document.getElementById('subscriber-count'),
        document.getElementById('subscriber-count-bottom'),
      ].filter(Boolean) as HTMLElement[];
      if (els.length === 0) return;

      const { count } = await supabase
        .from('subscribers')
        .select('*', { count: 'exact', head: true });

      const text = count && count > 0
        ? `Join ${count} ${count === 1 ? 'other' : 'others'} waiting for launch day.`
        : 'Be the first to get early access.';

      els.forEach(el => { el.textContent = text; });
    }

    // --- Init ---
    document.addEventListener('DOMContentLoaded', () => {
      startCountdown();
      setupEmailForms();
      loadMilestones();
      loadSubscriberCount();
    });
  </script>
</Layout>
